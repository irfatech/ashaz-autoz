---
interface Props {
  title: string;
  description: string;
  icon?: string;
  href?: string;
  features?: string[];
}

const { title, description, icon, href, features } = Astro.props;
---

<article class="rounded-2xl bg-card border-border shadow-sm hover:shadow-lg hover:border-accent-border hover:-translate-y-1 transition-all duration-300 p-6 sm:p-8 group">
  {icon && (
    <div class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl bg-accent-soft text-accent transition-all duration-300 group-hover:bg-accent group-hover:text-accent-text">
      <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
      </svg>
    </div>
  )}

  <h3 class="text-xl font-semibold mb-3">{title}</h3>
  <p class="text-muted leading-relaxed mb-4">{description}</p>

  {features && features.length > 0 && (
    <ul class="space-y-2 mb-5">
      {features.map((feature) => (
        <li class="flex items-center gap-2 text-sm text-body/70">
          <svg class="h-4 w-4 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
          </svg>
          {feature}
        </li>
      ))}
    </ul>
  )}

  {href && (
    <a
      href={href}
      class="inline-flex items-center gap-2 text-sm font-medium text-accent hover:text-accent-hover transition-colors"
      aria-label={`Learn more about ${title}`}
    >
      Learn More
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </a>
  )}
</article>
