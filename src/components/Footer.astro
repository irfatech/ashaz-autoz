---
const currentYear = new Date().getFullYear();

const columns = [
  {
    title: "Quick Links",
    links: [
      { label: "Home", href: "/" },
      { label: "About Us", href: "/about/" },
      { label: "Services", href: "/services/" },
      { label: "Vehicles", href: "/vehicles/" },
      { label: "Blog", href: "/blog/" },
      { label: "Contact", href: "/contact/" },
    ],
  },
  {
    title: "Services",
    links: [
      { label: "Vehicle Sales", href: "/services/vehicle-sales/" },
      { label: "Vehicle Import", href: "/services/vehicle-import/" },
      { label: "Car Rental", href: "/rentals/" },
      { label: "Workshop", href: "/workshop/" },
      { label: "Fleet Services", href: "/services/fleet-services/" },
    ],
  },
  {
    title: "Support",
    links: [
      { label: "FAQ", href: "/faq/" },
      { label: "Privacy Policy", href: "/privacy/" },
      { label: "Terms & Conditions", href: "/terms/" },
    ],
  },
];

const phones = ["77154379", "75249000", "73797973"];
const whatsappNumber = "67077154379";
const address = "Ponte Foun, Comoro, Dili, Timor-Leste";
const mapsHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`;
---

<footer class="bg-inverse text-inverted border-t border-white/10">

  <!-- CTA band -->
  <div class="border-b border-white/10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div>
        <p class="text-lg sm:text-xl font-semibold text-inverted">Looking for your next vehicle?</p>
        <p class="mt-1 text-sm text-muted">Browse current stock, or message us on WhatsApp — we usually reply within the hour.</p>
      </div>
      <div class="flex flex-wrap gap-3 shrink-0">
        <a
          href="/vehicles/"
          class="inline-flex items-center justify-center rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-inverse hover:opacity-90 transition-opacity focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          Browse Inventory
        </a>
        <a
          href={`https://wa.me/${whatsappNumber}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 justify-center rounded-md border border-white/20 px-5 py-2.5 text-sm font-semibold text-inverted hover:border-white/40 hover:bg-white/5 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 004.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0012.04 2zm0 18.13h-.01a8.2 8.2 0 01-4.18-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.22 8.22 0 01-1.26-4.36c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.83 2.42a8.17 8.17 0 012.41 5.83c0 4.55-3.7 8.21-8.25 8.21zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.78.97-.15.16-.29.18-.54.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.24-1.48-1.39-1.73-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.12-.15.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42-.14-.01-.31-.01-.47-.01-.16 0-.43.06-.66.31-.23.25-.86.84-.86 2.04 0 1.21.88 2.37 1 2.53.12.16 1.74 2.65 4.21 3.72.59.25 1.05.4 1.41.52.59.19 1.13.16 1.55.1.47-.07 1.47-.6 1.68-1.18.21-.58.21-1.08.15-1.18-.06-.1-.22-.16-.47-.28z"/></svg>
          Chat on WhatsApp
        </a>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 gap-x-6 gap-y-12 lg:grid-cols-12 lg:gap-x-8">

      <!-- Brand -->
      <div class="col-span-2 lg:col-span-4">
        <a href="/" class="text-2xl font-bold tracking-tight">
          <span class="text-accent">Ashaz</span>
          <span class="text-inverted">Autoz</span>
        </a>
        <p class="mt-4 text-muted leading-relaxed text-sm max-w-xs">
          Direct-from-Japan vehicle imports, sales, rentals, and workshop
          service — trusted across Dili since 2010.
        </p>

        <!-- Signature: import route -->
        <div class="mt-6 max-w-xs">
          <svg viewBox="0 0 260 36" class="w-full h-9 route-svg" aria-hidden="true">
            <line x1="26" y1="18" x2="234" y2="18" class="route-line" stroke-width="1.5" stroke-dasharray="4 5" />
            <g class="route-ship">
              <path d="M-7 -3.5h14l-2.5 6h-9z" fill="currentColor" class="text-accent" />
              <rect x="-1.5" y="-7" width="3" height="4" fill="currentColor" class="text-accent" />
            </g>
            <circle cx="20" cy="18" r="5" fill="none" stroke="currentColor" stroke-width="1.5" class="text-accent" />
            <circle cx="240" cy="18" r="5" fill="none" stroke="currentColor" stroke-width="1.5" class="text-accent" />
            <text x="20" y="33" text-anchor="middle" class="route-label">JP</text>
            <text x="240" y="33" text-anchor="middle" class="route-label">TL</text>
          </svg>
          <p class="mt-1 text-xs text-muted">Every import inspected before it reaches you.</p>
        </div>

        <div class="mt-6 flex gap-4">
          <a href="#" class="text-muted hover:text-accent transition-colors" aria-label="Facebook">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="text-muted hover:text-accent transition-colors" aria-label="Instagram">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0z"/></svg>
          </a>
          <a href="#" class="text-muted hover:text-accent transition-colors" aria-label="YouTube">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href={`https://wa.me/${whatsappNumber}`} target="_blank" rel="noopener noreferrer" class="text-muted hover:text-accent transition-colors" aria-label="WhatsApp">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 004.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0012.04 2zm0 18.13h-.01a8.2 8.2 0 01-4.18-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.22 8.22 0 01-1.26-4.36c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.83 2.42a8.17 8.17 0 012.41 5.83c0 4.55-3.7 8.21-8.25 8.21z"/></svg>
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {columns.map((col) => (
        <div class="col-span-1 lg:col-span-2">
          <h3 class="font-semibold text-sm uppercase tracking-widest text-accent mb-4">{col.title}</h3>
          <ul class="space-y-3">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-muted hover:text-inverted transition-colors text-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent rounded-sm"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Contact -->
      <div class="col-span-2 lg:col-span-2">
        <h3 class="font-semibold text-sm uppercase tracking-widest text-accent mb-4">Contact</h3>
        <ul class="space-y-4 text-sm text-muted">
          <li class="flex items-start gap-3">
            <svg class="h-5 w-5 mt-0.5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            <div>
              <span class="block">{address}</span>
              <a href={mapsHref} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline text-xs">Get directions</a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="h-5 w-5 mt-0.5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            <div>
              {phones.map((p) => (
                <a href={`tel:+${p}`} class="block hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent rounded-sm">
                  {p.slice(0, 4)} {p.slice(4)}
                </a>
              ))}
            </div>
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div class="flex items-center gap-2">
              <span>Mon–Sat, 8:00–17:30</span>
              <span class="inline-flex items-center gap-1.5 text-xs" id="open-status">
                <span class="h-1.5 w-1.5 rounded-full bg-white/30" id="open-status-dot"></span>
                <span id="open-status-label" class="text-muted"></span>
              </span>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10 py-6">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-muted">
      <p>&copy; {currentYear} Ashaz Autoz. All rights reserved.</p>
      <div class="flex items-center gap-6">
        <a href="/privacy/" class="hover:text-inverted transition-colors">Privacy Policy</a>
        <a href="/terms/" class="hover:text-inverted transition-colors">Terms & Conditions</a>
        <button
          id="back-to-top"
          type="button"
          aria-label="Back to top"
          class="inline-flex items-center gap-1.5 hover:text-inverted transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent rounded-sm"
        >
          Back to top
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5"/></svg>
        </button>
      </div>
    </div>
  </div>
</footer>

<style>
  .route-line {
    color: color-mix(in srgb, currentColor 35%, transparent);
  }
  .route-label {
    fill: currentColor;
    font-size: 9px;
    letter-spacing: 0.05em;
    opacity: 0.6;
  }
  .route-ship {
    animation: route-travel 5s ease-in-out infinite;
  }
  @keyframes route-travel {
    0% { transform: translateX(20px); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateX(218px); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .route-ship {
      animation: none;
      transform: translateX(119px);
      opacity: 1;
    }
  }
</style>

<script>
  // Live open/closed indicator, evaluated in Dili local time (Asia/Dili, UTC+9)
  function updateOpenStatus() {
    const dot = document.getElementById("open-status-dot");
    const label = document.getElementById("open-status-label");
    if (!dot || !label) return;

    const now = new Date();
    const diliTime = new Date(
      now.toLocaleString("en-US", { timeZone: "Asia/Dili" })
    );
    const day = diliTime.getDay(); // 0 = Sunday
    const minutes = diliTime.getHours() * 60 + diliTime.getMinutes();
    const opensAt = 8 * 60;
    const closesAt = 17 * 60 + 30;
    const isOpen = day !== 0 && minutes >= opensAt && minutes < closesAt;

    dot.className = `h-1.5 w-1.5 rounded-full ${isOpen ? "bg-emerald-400 animate-pulse" : "bg-white/30"}`;
    label.textContent = isOpen ? "Open now" : "Closed now";
  }

  updateOpenStatus();
  setInterval(updateOpenStatus, 60000);

  document.getElementById("back-to-top")?.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>