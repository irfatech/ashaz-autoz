---
import { generateBreadcrumbs } from "../lib/site";

interface Props {
  path: string;
  class?: string;
}

const { path } = Astro.props;
const crumbs = generateBreadcrumbs(path);
---

<nav aria-label="Breadcrumb" class={`flex items-center gap-2 text-sm text-muted ${Astro.props.class || ""}`}>
  {crumbs.map((crumb, i) => (
    <span class="flex items-center gap-2">
      {i > 0 && (
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      )}
      {i === crumbs.length - 1 ? (
        <span class="text-body font-medium">{crumb.label}</span>
      ) : (
        <a href={crumb.href} class="hover:text-accent transition-colors">{crumb.label}</a>
      )}
    </span>
  ))}
</nav>
