---

---

<section class="relative min-h-screen flex items-center bg-hero overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-hero/80 via-hero/60 to-hero/80 z-10" />

  <div class="absolute inset-0 bg-[url('/images/hero-bg.jpg')] bg-cover bg-center bg-no-repeat scale-105" />

  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(220,38,38,0.15),transparent_50%)]" />

  <div class="max-w-7xl px-4 sm:px-6 lg:px-8 relative z-20 py-32 lg:py-40">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-accent-soft border border-accent-border text-accent text-sm font-medium mb-8 animate-fade-in">
        <span class="h-2 w-2 rounded-full bg-accent animate-pulse" />
        Premium Automotive Services in Timor-Leste
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-8xl font-heading font-black text-white leading-[0.95] tracking-tight mb-6 animate-slide-up">
        Find the 
        <br />
        <span class="bg-linear-to-r from-accent to-accent-hover bg-clip-text text-transparent">Right Car</span>
      </h1>

      <p class="text-lg sm:text-xl text-white/70 max-w-xl mb-10 animate-slide-up" style="animation-delay: 0.1s">
        Discover quality vehicles with flexible options and a hassle-free buying experience. Every vehicle is inspected, competitively priced, and ready for your next journey.
      </p>

      <div class="flex flex-wrap gap-4 animate-slide-up" style="animation-delay: 0.2s">
        <a href="/vehicles/" class="inline-flex items-center justify-center gap-2 rounded-xl bg-accent text-accent-text px-8 py-4 text-lg font-medium hover:bg-accent-hover transition-all duration-200">
          Browse Vehicles
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a href="/contact/" class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-white/30 text-white px-8 py-4 text-lg font-medium hover:bg-white hover:text-black transition-all duration-200">
          Contact Us
        </a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-32 bg-linear-to-t from-page to-transparent z-10" />

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce">
    <svg class="h-8 w-8 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </div>
</section>
