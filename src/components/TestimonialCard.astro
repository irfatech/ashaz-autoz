---
interface Props {
  name: string;
  content: string;
  role?: string;
  company?: string;
  avatar?: string;
  rating?: number;
}

const { name, content, role, company, avatar, rating = 5 } = Astro.props;
---

<figure class="rounded-2xl bg-card border-border shadow-sm p-6 sm:p-8">
  <div class="flex gap-1 mb-4">
    {Array.from({ length: rating }, (_, i) => (
      <svg class="h-5 w-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  <blockquote class="text-body/80 leading-relaxed mb-6">
    "{content}"
  </blockquote>

  <figcaption class="flex items-center gap-4">
    <div class="h-12 w-12 rounded-full bg-accent/20 flex items-center justify-center text-accent font-semibold text-lg">
      {avatar ? (
        <img src={avatar} alt={name} class="h-full w-full rounded-full object-cover" loading="lazy" />
      ) : (
        name.charAt(0)
      )}
    </div>
    <div>
      <div class="font-semibold">{name}</div>
      {(role || company) && (
        <div class="text-sm text-muted">{role}{role && company ? ", " : ""}{company}</div>
      )}
    </div>
  </figcaption>
</figure>
