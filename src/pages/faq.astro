---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import { generateBreadcrumbs } from "../lib/site";
import { faqPageSchema } from "../lib/schema";

const crumbs = generateBreadcrumbs("/faq/");

const faqs = [
  { q: "What types of vehicles do you sell?", a: "We offer a wide range of vehicles including sedans, SUVs, 4x4s, trucks, minibuses, and luxury vehicles sourced from Japan, Singapore, and Australia." },
  { q: "Do you help with vehicle financing?", a: "Yes, we can assist with financing options. Please contact us to discuss your needs." },
  { q: "What is the process for importing a vehicle?", a: "We handle the entire import process including sourcing, documentation, customs clearance, and delivery. Contact us for a consultation." },
  { q: "How do I rent a vehicle?", a: "You can contact us by phone, WhatsApp, or visit our yard. We offer daily and monthly rental options with insurance included." },
  { q: "What workshop services do you offer?", a: "We offer oil changes, brake service, engine diagnostics, transmission service, tire service, AC repair, electrical repairs, and scheduled maintenance." },
  { q: "Do I need to book an appointment for the workshop?", a: "While walk-ins are welcome, we recommend booking an appointment to ensure timely service." },
  { q: "What are your operating hours?", a: "We are open Monday through Saturday, from 8:00 AM to 5:30 PM." },
  { q: "Where are you located?", a: "We are located at Ponte Foun, Comoro, Dili, Timor-Leste." },
  { q: "Do you offer test drives?", a: "Yes, test drives are available for vehicles in our inventory. Please contact us to schedule one." },
  { q: "What payment methods do you accept?", a: "We accept cash, bank transfers, and other payment methods. Please enquire for details." },
  { q: "Do you provide warranty on vehicles?", a: "Warranty terms vary by vehicle. We will provide full details during the purchase process." },
  { q: "Can you source a specific vehicle for me?", a: "Absolutely. If you're looking for a specific make and model, we can source it through our international networks." },
];
---

<BaseLayout
  title="FAQ"
  description="Frequently asked questions about Ashaz Autoz services."
  seo={{ breadcrumbs: crumbs }}
>
  {faqPageSchema(faqs) && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqPageSchema(faqs))} />
  )}
  <div class="pt-24">
    <section class="py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <Breadcrumb path="/faq/" class="mb-8" />
        <div class="section-title text-left max-w-2xl">
          <span class="text-accent font-semibold text-sm uppercase tracking-widest">FAQ</span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold tracking-tight mt-3 mb-6">
            Frequently Asked <span class="gradient-text">Questions</span>
          </h1>
          <p class="text-muted text-lg">
            Find answers to common questions about our services.
          </p>
        </div>
        <div class="max-w-3xl space-y-3 mt-12">
          {faqs.map((faq, i) => (
            <details class="card group open:border-accent-border transition-all duration-200">
              <summary class="flex items-center justify-between p-5 cursor-pointer list-none font-medium">
                <span>{faq.q}</span>
                <svg class="h-5 w-5 text-muted shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <div class="px-5 pb-5 text-muted leading-relaxed">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
