---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getCollection } from "astro:content";
import { formatPrice, formatMileage, getWhatsAppUrl, statusColors, phoneClean, getSiteSettings, generateBreadcrumbs } from "../../lib/site";
import { vehicleSchema } from "../../lib/schema";

export async function getStaticPaths() {
  const vehicles = await getCollection("vehicles");
  return vehicles.map((vehicle) => ({
    params: { slug: vehicle.id },
    props: { vehicle },
  }));
}

const { vehicle } = Astro.props;
const { data } = vehicle;
const settings = await getSiteSettings();
const phone = settings.social?.whatsapp ?? settings.phone[0];
const enquiryMessage = `Hello! I'm interested in the ${data.brand} ${data.model} (${data.year}) - ${formatPrice(data.price, data.currency)}. Is it still available?`;
const carSchema = vehicleSchema(
  { ...data, slug: vehicle.id, description: vehicle.body?.trim() || data.features?.join(", ") },
  `${settings.url}/vehicles/${vehicle.id}/`,
);
const crumbs = generateBreadcrumbs(`/vehicles/${vehicle.id}/`);
---

<BaseLayout
  title={`${data.brand} ${data.model} (${data.year})`}
  description={`${data.brand} ${data.model} ${data.year} - ${formatMileage(data.mileage)}, ${data.transmission}, ${data.fuelType}. ${formatPrice(data.price, data.currency)}.`}
  image={data.images?.[0]}
  seo={{ breadcrumbs: crumbs }}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(carSchema)} />
  <div class="pt-24">
    <section class="py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <Breadcrumb path={`/vehicles/${vehicle.id}/`} class="mb-8" />

        <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">
          <div>
            <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-muted/10 mb-4">
              <img
                src={data.images?.[0] || "/images/vehicle-placeholder.svg"}
                alt={`${data.brand} ${data.model}`}
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </div>
            {data.images && data.images.length > 1 && (
              <div class="grid grid-cols-4 gap-2">
                {data.images.slice(1, 5).map((img) => (
                  <div class="aspect-[4/3] rounded-lg overflow-hidden bg-muted/10">
                    <img src={img} alt="" class="h-full w-full object-cover" loading="lazy" />
                  </div>
                ))}
              </div>
            )}
          </div>

          <div>
            <div class="flex items-center gap-3 mb-4">
              <span class={`px-3 py-1 rounded-full text-xs font-semibold text-white ${statusColors[data.status]}`}>
                {data.status}
              </span>
              {data.featured && (
                <span class="px-3 py-1 rounded-full text-xs font-semibold bg-accent text-accent-text">Featured</span>
              )}
            </div>

            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-2">
              {data.brand} {data.model}
            </h1>
            <p class="text-muted text-lg mb-6">{data.year}</p>

            <div class="text-3xl sm:text-4xl font-bold text-accent mb-8">
              {formatPrice(data.price, data.currency)}
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-8">
              <div class="card p-4 text-center">
                <p class="text-xs text-muted uppercase tracking-wider mb-1">Mileage</p>
                <p class="font-semibold">{formatMileage(data.mileage)}</p>
              </div>
              <div class="card p-4 text-center">
                <p class="text-xs text-muted uppercase tracking-wider mb-1">Transmission</p>
                <p class="font-semibold">{data.transmission}</p>
              </div>
              <div class="card p-4 text-center">
                <p class="text-xs text-muted uppercase tracking-wider mb-1">Fuel</p>
                <p class="font-semibold">{data.fuelType}</p>
              </div>
              <div class="card p-4 text-center">
                <p class="text-xs text-muted uppercase tracking-wider mb-1">Drive</p>
                <p class="font-semibold">{data.driveType}</p>
              </div>
              <div class="card p-4 text-center">
                <p class="text-xs text-muted uppercase tracking-wider mb-1">Engine</p>
                <p class="font-semibold">{data.engine || "N/A"}</p>
              </div>
              <div class="card p-4 text-center">
                <p class="text-xs text-muted uppercase tracking-wider mb-1">Year</p>
                <p class="font-semibold">{data.year}</p>
              </div>
            </div>

            {data.features && data.features.length > 0 && (
              <div class="mb-8">
                <h2 class="text-lg font-semibold mb-4">Features</h2>
                <div class="grid grid-cols-2 gap-2">
                  {data.features.map((f) => (
                    <div class="flex items-center gap-2 text-sm">
                      <svg class="h-4 w-4 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                      </svg>
                      {f}
                    </div>
                  ))}
                </div>
              </div>
            )}

            <div class="flex flex-col sm:flex-row gap-3">
              <a
                href={getWhatsAppUrl(phone, enquiryMessage)}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 rounded-xl bg-accent text-accent-text px-6 py-3 font-medium hover:bg-accent-hover transition-all duration-200 flex-1 py-4 text-lg"
              >
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                Enquire on WhatsApp
              </a>
              <a href={`tel:${phoneClean(phone)}`} class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-btn-secondary-border text-btn-secondary-text px-6 py-3 font-medium hover:bg-btn-secondary-hover-bg hover:text-btn-secondary-hover-text transition-all duration-200 flex-1 py-4">
                Call {phoneClean(phone).replace(/(\d{4})(\d{4})/, "$1 $2")}
              </a>
            </div>

            <button id="share-btn" class="mt-4 inline-flex items-center justify-center gap-2 rounded-xl border border-border text-muted hover:text-body hover:bg-muted/10 px-4 py-2.5 text-sm font-medium transition-all duration-200 w-full">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z" /></svg>
              Share this vehicle
            </button>
          </div>
        </div>
      </div>
    </section>
  </div>
<script>
  document.getElementById("share-btn")?.addEventListener("click", async () => {
    const url = window.location.href;
    const title = document.title;
    const text = `Check out this ${title} at Ashaz Autoz`;

    if (navigator.share) {
      try {
        await navigator.share({ title, text, url });
        return;
      } catch {}
    }

    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(url);
      const btn = document.getElementById("share-btn");
      if (btn) {
        const orig = btn.innerHTML;
        btn.innerHTML = `<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg> Link copied!`;
        btn.classList.remove("border-border", "text-muted", "hover:text-body", "hover:bg-muted/10");
        btn.classList.add("border-green-500", "text-green-600");
        setTimeout(() => {
          btn.innerHTML = orig;
          btn.classList.add("border-border", "text-muted", "hover:text-body", "hover:bg-muted/10");
          btn.classList.remove("border-green-500", "text-green-600");
        }, 2500);
      }
    }
  });
</script>
</BaseLayout>
