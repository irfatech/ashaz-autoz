---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import ServiceCard from "../components/ServiceCard.astro";

const rentalBenefits = [
  { title: "Daily & Monthly Rentals", description: "Flexible rental periods to suit your needs, from daily to long-term." },
  { title: "Well-Maintained Fleet", description: "All vehicles are regularly serviced and maintained for your safety." },
  { title: "Insurance Included", description: "Comprehensive insurance coverage on all rental vehicles." },
  { title: "Airport Pickup", description: "Convenient airport pickup and drop-off available." },
  { title: "Competitive Rates", description: "Affordable pricing with no hidden fees." },
  { title: "Wide Selection", description: "Choose from sedans, SUVs, 4x4s, and more." },
];

const rentalFleet = [
  { name: "Economy Sedan", price: "From $45/day", seats: "5", transmission: "Manual/Auto", image: "/images/rental-1.jpg" },
  { name: "Midsize SUV", price: "From $75/day", seats: "7", transmission: "Automatic", image: "/images/rental-2.jpg" },
  { name: "4x4 Off-Road", price: "From $90/day", seats: "5", transmission: "Manual", image: "/images/rental-3.jpg" },
  { name: "Minibus", price: "From $120/day", seats: "12", transmission: "Manual", image: "/images/rental-4.jpg" },
];
---

<BaseLayout
  title="Car Rentals"
  description="Quality car rental services in Dili, Timor-Leste. Daily and monthly rates available."
>
  <div class="pt-24">
    <section class="py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <Breadcrumb path="/rentals/" class="mb-8" />
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div>
            <span class="text-accent font-semibold text-sm uppercase tracking-widest">Car Rental</span>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold tracking-tight mt-3 mb-6">
              Rent a Vehicle<br />
              <span class="gradient-text">in Dili</span>
            </h1>
            <p class="text-muted text-lg leading-relaxed mb-8">
              Whether you need a car for a day, a week, or a month, Ashaz Autoz has you covered. Our fleet of well-maintained vehicles is ready for any journey across Timor-Leste.
            </p>
            <a href="/contact/" class="inline-flex items-center justify-center gap-2 rounded-xl bg-accent text-accent-text px-6 py-3 font-medium hover:bg-accent-hover transition-all duration-200 text-lg px-8 py-4">
              Book a Rental
            </a>
          </div>
          <div class="aspect-[4/3] rounded-2xl overflow-hidden">
            <img src="/images/rental-hero.jpg" alt="Car rental fleet" class="h-full w-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-20 lg:py-24 bg-section">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="section-title">
          <h2>Our Rental <span class="gradient-text">Fleet</span></h2>
          <p>Choose from our range of quality rental vehicles.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {rentalFleet.map((vehicle) => (
            <div class="card card-hover overflow-hidden">
              <div class="aspect-[4/3] bg-muted/10">
                <img src={vehicle.image} alt={vehicle.name} class="h-full w-full object-cover" loading="lazy" />
              </div>
              <div class="p-5">
                <h3 class="font-semibold text-lg mb-1">{vehicle.name}</h3>
                <p class="text-accent font-bold text-xl mb-3">{vehicle.price}</p>
                <div class="flex items-center gap-4 text-sm text-muted">
                  <span class="flex items-center gap-1">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
                    {vehicle.seats} seats
                  </span>
                  <span>{vehicle.transmission}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="section-title">
          <h2>Why Rent With <span class="gradient-text">Us</span></h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {rentalBenefits.map((benefit) => (
            <div class="card p-6">
              <h3 class="font-semibold mb-2">{benefit.title}</h3>
              <p class="text-muted text-sm">{benefit.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-20 lg:py-24 bg-inverse">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-inverted mb-4">Ready to Rent?</h2>
        <p class="text-inverted/60 text-lg max-w-2xl mx-auto mb-8">
          Contact us to reserve your vehicle today.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact/" class="inline-flex items-center justify-center gap-2 rounded-xl bg-accent text-accent-text px-6 py-3 font-medium hover:bg-accent-hover transition-all duration-200 text-lg px-8 py-4">Book Now</a>
          <a href="tel:+67077154379" class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-inverted/30 text-inverted font-medium transition-all duration-200 text-lg px-8 py-4 hover:bg-inverted hover:text-inverse">Call 7715 4379</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
