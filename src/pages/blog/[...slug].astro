---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { data } = post;
const { Content } = await render(post);
---

<BaseLayout
  title={data.title}
  description={data.excerpt}
  image={data.image}
  seo={{
    type: "article",
    publishedTime: data.date.toISOString(),
    author: data.author,
  }}
>
  <div class="pt-24">
    <section class="py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <Breadcrumb path={`/blog/${post.id}/`} class="mb-8" />
        <article class="max-w-3xl mx-auto">
          <div class="mb-8">
            <div class="flex items-center gap-3 text-sm text-muted mb-4">
              <span class="px-3 py-1 rounded-full bg-accent-soft text-accent text-xs font-medium">{data.category}</span>
              <time datetime={data.date.toISOString()}>
                {new Intl.DateTimeFormat("en-US", { month: "long", day: "numeric", year: "numeric" }).format(data.date)}
              </time>
              <span>•</span>
              <span>{data.author}</span>
            </div>

            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6">{data.title}</h1>
            <p class="text-lg text-muted">{data.excerpt}</p>
          </div>

          {data.image && (
            <div class="aspect-[16/9] rounded-2xl overflow-hidden mb-10">
              <img src={data.image} alt={data.title} class="h-full w-full object-cover" loading="lazy" />
            </div>
          )}

          <div class="prose prose-lg dark:prose-invert max-w-none">
            <Content />
          </div>

          {data.tags && data.tags.length > 0 && (
            <div class="mt-10 pt-8 border-t border-border">
              <div class="flex flex-wrap gap-2">
                {data.tags.map((tag) => (
                  <span class="px-3 py-1 rounded-full bg-muted/10 text-sm text-muted">{tag}</span>
                ))}
              </div>
            </div>
          )}

          <div class="mt-10 pt-8 border-t border-border flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <a href="/blog/" class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-btn-secondary-border text-btn-secondary-text px-6 py-3 font-medium hover:bg-btn-secondary-hover-bg hover:text-btn-secondary-hover-text transition-all duration-200">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
              Back to Blog
            </a>
          </div>
        </article>
      </div>
    </section>
  </div>
</BaseLayout>
