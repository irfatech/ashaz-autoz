---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import ServiceCard from "../components/ServiceCard.astro";
import { getCollection } from "astro:content";
import { generateBreadcrumbs } from "../lib/site";

const crumbs = generateBreadcrumbs("/services/");

const services = (await getCollection("services"))
  .sort((a, b) => a.data.order - b.data.order)
  .map((s) => ({
    title: s.data.title,
    description: s.data.description,
    features: s.data.features,
    href: `/services/${s.data.slug ?? s.id}/`,
    icon: s.data.icon,
    ctaText: s.data.ctaText,
  }));
---

<BaseLayout
  title="Services"
  description="Comprehensive automotive services in Timor-Leste — vehicle sales, imports, rentals, workshop, and more."
  seo={{ breadcrumbs: crumbs }}
>
  <div class="pt-24">
    <section class="py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <Breadcrumb path="/services/" class="mb-8" />
        <div class="section-title text-left max-w-2xl">
          <span class="text-accent font-semibold text-sm uppercase tracking-widest">What We Offer</span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold tracking-tight mt-3 mb-6">
            Our <span class="gradient-text">Services</span>
          </h1>
          <p class="text-muted text-lg">
            From buying and importing vehicles to renting and maintaining them, we provide complete automotive solutions under one roof.
          </p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mt-12">
          {services.map((service) => (
            <ServiceCard {...service} />
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-20 lg:py-24 bg-inverse">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-inverted mb-4">Need a Custom Solution?</h2>
        <p class="text-inverted/60 text-lg max-w-2xl mx-auto mb-8">
          Contact us to discuss your specific automotive requirements. We're here to help.
        </p>
        <a href="/contact/" class="inline-flex items-center justify-center gap-2 rounded-xl bg-accent text-accent-text px-6 py-3 font-medium hover:bg-accent-hover transition-all duration-200 text-lg px-8 py-4">
          Get in Touch
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
