---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import { getSiteSettings } from "../lib/site";

const settings = await getSiteSettings();
const phoneClean = (p: string) => p.replace(/[^0-9]/g, "");
const phoneDisplay = (p: string) => phoneClean(p).replace(/(\d{4})(\d{4})(\d+)?/, (_, a, b, c) => c ? `${a} ${b} ${c}` : `${a} ${b}`);
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with Ashaz Autoz. Visit our yard in Comoro, Dili or call us."
>
  <div class="pt-24">
    <section class="py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <Breadcrumb path="/contact/" class="mb-8" />
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
          <div>
            <span class="text-accent font-semibold text-sm uppercase tracking-widest">Contact</span>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold tracking-tight mt-3 mb-6">
              Get in <span class="gradient-text">Touch</span>
            </h1>
            <p class="text-muted text-lg leading-relaxed mb-10">
              We'd love to hear from you. Whether you're looking for a vehicle, need a service, or have a question, our team is ready to help.
            </p>

            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="h-12 w-12 rounded-xl bg-accent-soft flex items-center justify-center shrink-0">
                  <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold">Address</h3>
                  <p class="text-muted mt-1">{settings.address}</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="h-12 w-12 rounded-xl bg-accent-soft flex items-center justify-center shrink-0">
                  <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold">Phone</h3>
                  <p class="text-muted mt-1">
                    {settings.phone.map((p) => (
                      <a href={`tel:${phoneClean(p)}`} class="block hover:text-accent">{phoneDisplay(p)}</a>
                    ))}
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="h-12 w-12 rounded-xl bg-accent-soft flex items-center justify-center shrink-0">
                  <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold">Working Hours</h3>
                  <p class="text-muted mt-1">{settings.workingHours}</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="h-12 w-12 rounded-xl bg-accent-soft flex items-center justify-center shrink-0">
                  <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold">WhatsApp</h3>
                  <p class="text-muted mt-1">
                    <a href={`https://wa.me/${phoneClean(settings.social?.whatsapp ?? settings.phone[0])}`} target="_blank" rel="noopener noreferrer" class="hover:text-accent">
                      Chat with us on WhatsApp
                    </a>
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="card p-6 sm:p-8">
            <h2 class="text-2xl font-semibold mb-6">Send Us a Message</h2>
            <form id="contact-form" class="space-y-5">
              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-medium mb-2">Full Name</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full rounded-xl border border-accent-border/20 bg-transparent px-4 py-3 text-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors"
                    placeholder="Your name"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium mb-2">Email</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full rounded-xl border border-accent-border/20 bg-transparent px-4 py-3 text-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors"
                    placeholder="your@email.com"
                  />
                </div>
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium mb-2">Phone</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full rounded-xl border border-accent-border/20 bg-transparent px-4 py-3 text-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors"
                  placeholder="+670 ..."
                />
              </div>
              <div>
                <label for="subject" class="block text-sm font-medium mb-2">Subject</label>
                <select
                  id="subject"
                  name="subject"
                  class="w-full rounded-xl border border-accent-border/20 bg-transparent px-4 py-3 text-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors"
                >
                  <option value="">Select a subject</option>
                  <option value="vehicle-sales">Vehicle Sales</option>
                  <option value="vehicle-import">Vehicle Import</option>
                  <option value="rental">Car Rental</option>
                  <option value="workshop">Workshop & Maintenance</option>
                  <option value="general">General Enquiry</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium mb-2">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full rounded-xl border border-accent-border/20 bg-transparent px-4 py-3 text-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors resize-none"
                  placeholder="How can we help you?"
                ></textarea>
              </div>
              <button type="submit" class="inline-flex items-center justify-center gap-2 rounded-xl bg-accent text-accent-text px-6 py-3 font-medium hover:bg-accent-hover transition-all duration-200 w-full py-4">
                Send Message
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" /></svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="h-[450px] w-full bg-muted/10">
        <iframe
          src={settings.googleMapsEmbedUrl}
          width="100%"
          height="100%"
          style="border: 0"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ashaz Autoz Location"
        ></iframe>
      </div>
    </section>
  </div>
</BaseLayout>
