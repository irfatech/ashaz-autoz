---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TikTokCard from "../../components/TikTokCard.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getCollection } from "astro:content";
import { generateBreadcrumbs } from "../../lib/site";
import { videoObjectSchema } from "../../lib/schema";

const crumbs = generateBreadcrumbs("/tiktok/");

const allVideos = await getCollection("tiktok");
allVideos.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const categories = [...new Set(allVideos.map((v) => v.data.category))].sort();

const videoData = videoObjectSchema(
  allVideos.map((v) => ({
    name: v.data.title,
    description: v.data.caption,
    thumbnailUrl: v.data.thumbnail,
    contentUrl: v.data.tiktokUrl,
    embedUrl: v.data.tiktokUrl,
    uploadDate: v.data.date?.toISOString() || new Date().toISOString(),
  })),
);
---

<BaseLayout
  title="TikTok Videos"
  description="Follow Ashaz Autoz on TikTok for vehicle showcases, imports, workshop tips, and more."
  seo={{ breadcrumbs: crumbs }}
>
  {videoData && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(videoData)} />
  )}
  <div class="pt-24">
    <section class="py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <Breadcrumb path="/tiktok/" class="mb-8" />
        <div class="text-center mb-12">
          <span class="text-accent font-semibold text-sm uppercase tracking-widest">TikTok</span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mt-3 mb-4">
            Follow Us on <span class="gradient-text">TikTok</span>
          </h1>
          <p class="text-muted text-lg max-w-2xl mx-auto">
            Behind-the-scenes, vehicle showcases, imports, workshop tips, and customer stories.
          </p>
          <a
            href="https://www.tiktok.com/@ashazautoztimorleste"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mt-6 rounded-xl bg-accent text-accent-text px-6 py-3 font-medium hover:bg-accent-hover transition-all duration-200"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.9 2.89 2.89 0 0 1-2.88-2.89 2.89 2.89 0 0 1 2.88-2.89c.39 0 .76.08 1.1.22V8.68a6.37 6.37 0 0 0-1.1-.12 6.34 6.34 0 0 0-6.33 6.34 6.34 6.34 0 0 0 6.33 6.34 6.34 6.34 0 0 0 6.33-6.34V7.05a8.24 8.24 0 0 0 4.78 1.64v-2a4.84 4.84 0 0 1-1.1.02z"/></svg>
            @ashazautoztimorleste
          </a>
        </div>

        <div class="flex flex-wrap items-center gap-3 mb-10" id="tiktok-filters">
          <button class="filter-btn active px-4 py-2 rounded-full text-sm font-medium border border-border bg-card text-body hover:bg-accent hover:text-accent-text hover:border-accent transition-all" data-filter="all">
            All
          </button>
          {categories.map((cat) => (
            <button class="filter-btn px-4 py-2 rounded-full text-sm font-medium border border-border bg-card text-body hover:bg-accent hover:text-accent-text hover:border-accent transition-all" data-filter={cat}>
              {cat}
            </button>
          ))}
          <div class="ml-auto flex items-center gap-2">
            <label for="sort" class="text-sm text-muted">Sort:</label>
            <select id="sort" class="rounded-lg border border-border bg-card px-3 py-2 text-sm text-body focus:outline-none focus:ring-1 focus:ring-accent">
              <option value="order">Featured Order</option>
              <option value="newest">Newest</option>
            </select>
          </div>
        </div>

        <div class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-4 space-y-4" id="tiktok-grid">
          {allVideos.map((video) => (
            <div class="tiktok-item break-inside-avoid" data-category={video.data.category}>
              <TikTokCard video={video} />
            </div>
          ))}
        </div>

        {allVideos.length === 0 && (
          <div class="text-center py-20">
            <p class="text-muted text-lg">No videos yet. Check back soon!</p>
          </div>
        )}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  import { setupGalleryFilter } from "../../lib/gallery-filter";

  setupGalleryFilter({
    filterBtnSelector: ".filter-btn",
    itemSelector: ".tiktok-item",
    gridId: "tiktok-grid",
    sortSelectId: "sort",
  });
</script>
