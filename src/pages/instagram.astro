---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
---

<BaseLayout
  title="Instagram Video Preview"
  description="Watch our latest Instagram videos showcasing vehicles and services."
>
  <div class="pt-24">
    <section class="py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <Breadcrumb path="/instagram/" class="mb-8" />
        <div class="section-title">
          <span class="text-accent font-semibold text-sm uppercase tracking-widest">Social</span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold tracking-tight mt-3 mb-6">
            Instagram <span class="gradient-text">Videos</span>
          </h1>
          <p class="text-muted text-lg">
            Follow us on Instagram for the latest vehicle showcases, behind-the-scenes, and more.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
          {[1, 2, 3, 4, 5, 6].map((i) => (
            <div class="card overflow-hidden group" key={i}>
              <div class="aspect-[9/16] bg-muted/10 flex items-center justify-center relative">
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="h-16 w-16 text-white/50" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
                <img
                  src={`/images/instagram-video-${i}.jpg`}
                  alt="Instagram video"
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>
              <div class="p-4">
                <p class="text-sm text-muted">Latest from our Instagram</p>
              </div>
            </div>
          ))}
        </div>

        <div class="text-center mt-10">
          <a
            href="https://www.instagram.com/ashazautoz"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-accent text-accent-text px-6 py-3 font-medium hover:bg-accent-hover transition-all duration-200 inline-flex"
          >
            Follow on Instagram
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0z"/></svg>
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
