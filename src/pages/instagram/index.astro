---
import BaseLayout from "../../layouts/BaseLayout.astro";
import InstagramCard from "../../components/InstagramCard.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getCollection } from "astro:content";
import { generateBreadcrumbs } from "../../lib/site";
import { imageGallerySchema } from "../../lib/schema";

const crumbs = generateBreadcrumbs("/instagram/");
const allPosts = await getCollection("instagram");
allPosts.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const categories = [...new Set(allPosts.map((p) => p.data.category))].sort();

const galleryData = imageGallerySchema(
  allPosts.map((p) => ({
    url: p.data.instagramUrl,
    caption: p.data.caption || p.data.title,
  })),
);
---

<BaseLayout
  title="Instagram"
  description="Follow Ashaz Autoz on Instagram for vehicle showcases, imports, workshop updates, and more."
  seo={{ breadcrumbs: crumbs }}
>
  {galleryData && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(galleryData)} />
  )}
  <div class="pt-24">
    <section class="py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <Breadcrumb path="/instagram/" class="mb-8" />
        <div class="text-center mb-12">
          <span class="text-accent font-semibold text-sm uppercase tracking-widest">Social</span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mt-3 mb-4">
            Instagram <span class="gradient-text">Feed</span>
          </h1>
          <p class="text-muted text-lg max-w-2xl mx-auto">
            Vehicle showcases, imports, workshop updates, and customer stories.
          </p>
          <a
            href="https://www.instagram.com/ashazautoz"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mt-6 rounded-xl bg-accent text-accent-text px-6 py-3 font-medium hover:bg-accent-hover transition-all duration-200"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0z"/></svg>
            @ashazautoz
          </a>
        </div>

        <div class="flex flex-wrap items-center gap-3 mb-10" id="ig-filters">
          <button class="filter-btn active px-4 py-2 rounded-full text-sm font-medium border border-border bg-card text-body hover:bg-accent hover:text-accent-text hover:border-accent transition-all" data-filter="all">
            All
          </button>
          {categories.map((cat) => (
            <button class="filter-btn px-4 py-2 rounded-full text-sm font-medium border border-border bg-card text-body hover:bg-accent hover:text-accent-text hover:border-accent transition-all" data-filter={cat}>
              {cat}
            </button>
          ))}
          <div class="ml-auto flex items-center gap-2">
            <label for="sort" class="text-sm text-muted">Sort:</label>
            <select id="sort" class="rounded-lg border border-border bg-card px-3 py-2 text-sm text-body focus:outline-none focus:ring-1 focus:ring-accent">
              <option value="order">Featured Order</option>
              <option value="newest">Newest</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4" id="ig-grid">
          {allPosts.map((post) => (
            <div class="ig-item" data-category={post.data.category} data-order={post.data.order || 99} data-date={post.data.date?.toISOString() || ""}>
              <InstagramCard post={post} />
            </div>
          ))}
        </div>

        {allPosts.length === 0 && (
          <div class="text-center py-20">
            <p class="text-muted text-lg">No posts yet. Check back soon!</p>
          </div>
        )}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  import { setupGalleryFilter } from "../../lib/gallery-filter";

  setupGalleryFilter({
    filterBtnSelector: "#ig-filters .filter-btn",
    itemSelector: ".ig-item",
    gridId: "ig-grid",
    sortSelectId: "sort",
  });
</script>
