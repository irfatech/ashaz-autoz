---
import "../../../styles/global.css"
import { APP_PASSWORD } from "../../../lib/auth"
---
<!doctype html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>New Quotation — Ashaz Autoz</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script>
    if (sessionStorage.getItem("app_auth") !== "true") {
      window.location.replace("/app/")
    }
  </script>
  <script>
    if (localStorage.getItem("theme") !== "light") {
      document.documentElement.classList.add("dark")
    }
  </script>
</head>
<body class="bg-page text-body font-sans antialiased">
  <nav class="sticky top-0 z-40 border-b border-border bg-page/80 backdrop-blur-md">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 flex items-center justify-between h-14">
      <div class="flex items-center gap-3">
        <a href="/app/quotations/" class="text-muted hover:text-body transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
        </a>
        <span class="text-sm font-semibold">New Quotation</span>
      </div>
      <div class="flex items-center gap-3">
        <a href="/" class="text-xs text-muted hover:text-accent transition-colors">Site</a>
        <button id="logout-btn" class="text-xs text-muted hover:text-red-500 transition-colors">Logout</button>
      </div>
    </div>
  </nav>

  <div class="mx-auto max-w-5xl px-4 sm:px-6 py-8">
    <form id="doc-form" class="space-y-8">

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1">Date</label>
          <input type="date" id="doc-date" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1">Valid Until</label>
          <input type="date" id="doc-valid" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
        </div>
      </div>

      <div>
        <h2 class="text-sm font-bold text-accent uppercase tracking-wider mb-3">Customer Details</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <input id="cust-name" placeholder="Customer Name" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
          <input id="cust-phone" placeholder="Phone" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
          <input id="cust-email" type="email" placeholder="Email" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
          <input id="cust-address" placeholder="Address" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
        </div>
      </div>

      <div>
        <h2 class="text-sm font-bold text-accent uppercase tracking-wider mb-3">Vehicle Details</h2>
        <div class="grid sm:grid-cols-3 gap-4">
          <input id="v-brand" placeholder="Brand" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
          <input id="v-model" placeholder="Model" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
          <input id="v-year" type="number" placeholder="Year" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
          <input id="v-vin" placeholder="VIN" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
          <input id="v-mileage" type="number" placeholder="Mileage (km)" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
          <input id="v-color" placeholder="Color" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
          <input id="v-transmission" placeholder="Transmission" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
          <input id="v-fuel" placeholder="Fuel Type" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
          <input id="v-engine" placeholder="Engine" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-bold text-accent uppercase tracking-wider">Line Items</h2>
          <button type="button" id="add-item" class="text-xs font-medium text-accent hover:text-accent-hover transition-colors">+ Add Item</button>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm" id="items-table">
            <thead>
              <tr class="border-b border-border">
                <th class="text-left py-2 pr-2 text-xs text-muted font-semibold w-1/2">Description</th>
                <th class="text-center py-2 px-2 text-xs text-muted font-semibold w-16">Qty</th>
                <th class="text-right py-2 px-2 text-xs text-muted font-semibold w-28">Unit Price</th>
                <th class="text-right py-2 px-2 text-xs text-muted font-semibold w-28">Total</th>
                <th class="w-10"></th>
              </tr>
            </thead>
            <tbody id="items-body">
            </tbody>
          </table>
        </div>
        <div class="text-xs text-muted mt-2">Tip: Add "Vehicle Price" as the first line item for the total vehicle cost.</div>
      </div>

      <div class="grid sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1">Tax Rate (%)</label>
          <input type="number" id="tax-rate" value="0" min="0" max="100" step="0.5" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1">Discount ($)</label>
          <input type="number" id="discount" value="0" min="0" step="100" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
        </div>
        <div class="flex flex-col justify-end">
          <div class="text-right">
            <div class="text-xs text-muted">Subtotal: <span id="calc-subtotal" class="text-body font-semibold">$0</span></div>
            <div class="text-xs text-muted">Tax: <span id="calc-tax" class="text-body font-semibold">$0</span></div>
            <div class="text-lg font-bold text-accent mt-1">Total: <span id="calc-total">$0</span></div>
          </div>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1">Notes</label>
          <textarea id="notes" rows="3" placeholder="Additional notes…" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent resize-none"></textarea>
        </div>
        <div>
          <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1">Terms & Conditions</label>
          <textarea id="terms" rows="3" placeholder="Payment terms, warranty, etc…" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent resize-none">Payment due within 7 days. All prices in USD. Vehicle subject to prior sale.</textarea>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1">Authorized Signatory Name</label>
          <input id="signatory-name" placeholder="e.g. John Doe" value="Ashaz Autoz" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1">Customer Name (for signature)</label>
          <input id="cust-sig-name" placeholder="Customer name" class="w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent" />
        </div>
      </div>

      <div class="flex gap-3 pt-4 border-t border-border">
        <button type="button" id="generate-btn" class="flex-1 inline-flex items-center justify-center gap-2 rounded-xl bg-accent text-accent-text px-6 py-3 font-medium hover:bg-accent-hover transition-all duration-200">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
          Generate Quotation PDF
        </button>
        <button type="button" id="print-btn" class="inline-flex items-center justify-center gap-2 rounded-xl border border-border text-muted px-4 py-3 font-medium hover:text-body hover:bg-muted/10 transition-all duration-200">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5zm-3 0h.008v.008H15V10.5z" /></svg>
          Print
        </button>
        <button type="button" id="save-btn" class="inline-flex items-center justify-center gap-2 rounded-xl border border-border text-muted px-4 py-3 font-medium hover:text-body hover:bg-muted/10 transition-all duration-200">
          Save Only
        </button>
      </div>
    </form>
  </div>

  <div id="pdf-render-target" style="position:fixed;top:0;left:0;width:794px;background:#fff;pointer-events:none;z-index:9999;"></div>

  <script type="module">
    import { isAuthenticated, logout } from "../../../lib/auth"
    import { generateDocId, generateDocNumber, saveDocument } from "../../../lib/documents"
    import { generatePdf } from "../../../lib/pdf"
    import { buildPdfHtml } from "../../../lib/pdfTemplate"

    if (!isAuthenticated()) window.location.replace("/app/")

    document.getElementById("logout-btn")?.addEventListener("click", () => { logout(); window.location.replace("/app/") })

    const today = new Date()
    const fmt = (d) => d.toISOString().split("T")[0]
    document.getElementById("doc-date").value = fmt(today)
    const validUntil = new Date(today); validUntil.setDate(validUntil.getDate() + 30)
    document.getElementById("doc-valid").value = fmt(validUntil)

    const params = new URLSearchParams(window.location.search)
    const vehicleParam = params.get("vehicle")
    if (vehicleParam) {
      try {
        const v = JSON.parse(decodeURIComponent(vehicleParam))
        const setVal = (id, val) => { const el = document.getElementById(id); if (el && val) el.value = val }
        setVal("v-brand", v.brand)
        setVal("v-model", v.model)
        setVal("v-year", v.year?.toString())
        setVal("v-vin", v.vin)
        setVal("v-mileage", v.mileage?.toString())
        setVal("v-color", v.color)
        setVal("v-transmission", v.transmission)
        setVal("v-fuel", v.fuelType)
        setVal("v-engine", v.engine)
      } catch {}
    }

    let itemCount = 0
    function addItem(description = "", quantity = 1, unitPrice = 0) {
      itemCount++
      const id = `item-${itemCount}`
      const tbody = document.getElementById("items-body")
      const tr = document.createElement("tr")
      tr.id = id
      tr.className = "border-b border-border/50"
      tr.innerHTML = `
        <td class="py-2 pr-2"><input type="text" class="item-desc w-full bg-transparent px-2 py-1.5 text-sm focus:outline-none" placeholder="Item description" value="${description}" /></td>
        <td class="py-2 px-2"><input type="number" class="item-qty w-full bg-transparent text-center px-2 py-1.5 text-sm focus:outline-none" value="${quantity}" min="1" /></td>
        <td class="py-2 px-2"><input type="number" class="item-price w-full bg-transparent text-right px-2 py-1.5 text-sm focus:outline-none" value="${unitPrice}" min="0" step="100" /></td>
        <td class="py-2 px-2 text-right font-medium item-total">$${Number(unitPrice * quantity).toLocaleString()}</td>
        <td class="py-2"><button type="button" class="remove-item text-muted hover:text-red-500 transition-colors p-1"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg></button></td>
      `
      tbody.appendChild(tr)

      const inputs = tr.querySelectorAll("input")
      inputs.forEach((inp) => inp.addEventListener("input", recalcItem))
      tr.querySelector(".remove-item")?.addEventListener("click", () => { tr.remove(); recalcAll() })
    }

    function recalcItem() {
      const row = this?.closest?.("tr") || this?.parentElement?.closest?.("tr")
      if (!row) return
      const qty = Number(row.querySelector(".item-qty")?.value || 0)
      const price = Number(row.querySelector(".item-price")?.value || 0)
      const total = qty * price
      row.querySelector(".item-total").textContent = `$${total.toLocaleString()}`
      recalcAll()
    }

    function recalcAll() {
      let subtotal = 0
      document.querySelectorAll("#items-body tr").forEach((row) => {
        const qty = Number(row.querySelector(".item-qty")?.value || 0)
        const price = Number(row.querySelector(".item-price")?.value || 0)
        subtotal += qty * price
      })
      const taxRate = Number(document.getElementById("tax-rate")?.value || 0)
      const discount = Number(document.getElementById("discount")?.value || 0)
      const tax = subtotal * (taxRate / 100)
      const total = subtotal + tax - discount

      document.getElementById("calc-subtotal").textContent = `$${subtotal.toLocaleString()}`
      document.getElementById("calc-tax").textContent = `$${tax.toLocaleString()}`
      document.getElementById("calc-total").textContent = `$${Math.max(0, total).toLocaleString()}`
    }

    function getFormData() {
      const getVal = (id) => document.getElementById(id)?.value || ""
      const items = Array.from(document.querySelectorAll("#items-body tr")).map((row) => {
        const desc = row.querySelector(".item-desc")?.value || ""
        const qty = Number(row.querySelector(".item-qty")?.value || 0)
        const price = Number(row.querySelector(".item-price")?.value || 0)
        return { id: generateDocId(), description: desc, quantity: qty, unitPrice: price, total: qty * price }
      })
      return {
        id: generateDocId(),
        type: "quotation",
        number: generateDocNumber("quotation"),
        date: getVal("doc-date"),
        validUntil: getVal("doc-valid"),
        customer: {
          name: getVal("cust-name"),
          phone: getVal("cust-phone"),
          email: getVal("cust-email"),
          address: getVal("cust-address"),
        },
        vehicle: {
          brand: getVal("v-brand"),
          model: getVal("v-model"),
          year: Number(getVal("v-year")) || 0,
          vin: getVal("v-vin"),
          mileage: Number(getVal("v-mileage")) || 0,
          color: getVal("v-color"),
          transmission: getVal("v-transmission"),
          fuelType: getVal("v-fuel"),
          engine: getVal("v-engine"),
        },
        lineItems: items,
        taxRate: Number(getVal("tax-rate")) || 0,
        discount: Number(getVal("discount")) || 0,
        notes: getVal("notes"),
        terms: getVal("terms"),
        signatoryName: getVal("signatory-name"),
        customerName: getVal("cust-sig-name"),
      }
    }

    document.getElementById("add-item")?.addEventListener("click", () => addItem())
    addItem("Vehicle Price", 1, 0)

    document.getElementById("tax-rate")?.addEventListener("input", recalcAll)
    document.getElementById("discount")?.addEventListener("input", recalcAll)

    document.getElementById("generate-btn")?.addEventListener("click", async () => {
      const btn = document.getElementById("generate-btn")
      btn.textContent = "Generating…"
      btn.disabled = true

      try {
        const data = getFormData()
        saveDocument(data)
        const html = buildPdfHtml(data)
        const target = document.getElementById("pdf-render-target")
        target.innerHTML = html
        await generatePdf(target, `${data.number}.pdf`)
        target.innerHTML = ""
      } catch (err) {
        alert("Failed to generate PDF: " + err.message)
      }

      btn.textContent = "Generate Quotation PDF"
      btn.disabled = false
    })

    document.getElementById("print-btn")?.addEventListener("click", () => {
      const data = getFormData()
      saveDocument(data)
      const html = buildPdfHtml(data)
      const pw = window.open("", "_blank", "width=800,height=600")
      if (pw) {
        pw.document.write(html)
        pw.document.close()
        pw.focus()
        pw.onafterprint = () => pw.close()
      }
    })

    document.getElementById("save-btn")?.addEventListener("click", () => {
      const data = getFormData()
      saveDocument(data)
      window.location.href = "/app/quotations/"
    })
  </script>
</body>
</html>
