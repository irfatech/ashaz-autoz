---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getCollection, render } from "astro:content";
import { generateBreadcrumbs } from "../../lib/site";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((service) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const { data } = service;
const { Content } = await render(service);
const crumbs = generateBreadcrumbs(`/services/${service.id}/`);
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={data.image}
  seo={{ breadcrumbs: crumbs }}
>
  <div class="pt-24">
    <section class="py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <Breadcrumb path={`/services/${service.id}/`} class="mb-8" />
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
          <div>
            <span class="text-accent font-semibold text-sm uppercase tracking-widest">Service</span>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold tracking-tight mt-3 mb-6">{data.title}</h1>
            <p class="text-muted text-lg leading-relaxed mb-8">{data.description}</p>

            {data.features && data.features.length > 0 && (
              <div class="mb-8">
                <h2 class="text-lg font-semibold mb-4">What We Offer</h2>
                <ul class="space-y-3">
                  {data.features.map((f) => (
                    <li class="flex items-center gap-3">
                      <svg class="h-5 w-5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                      </svg>
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <a href="/contact/" class="inline-flex items-center justify-center gap-2 rounded-xl bg-accent text-accent-text px-6 py-3 font-medium hover:bg-accent-hover transition-all duration-200 text-lg px-8 py-4">
              {data.ctaText || "Get in Touch"}
            </a>
          </div>

          <div class="aspect-[4/3] rounded-2xl overflow-hidden">
            <img
              src={data.image || "/images/service-default.webp"}
              alt={data.title}
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>

        <div class="mt-16 prose prose-lg dark:prose-invert max-w-none">
          <Content />
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
